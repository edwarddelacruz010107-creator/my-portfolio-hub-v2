# Secrets / local env
.env
.env.*
!.env.example

# Python cache / test cache
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# Editors / OS files
.vscode/
_vscode/
.idea/
.DS_Store
Thumbs.db

# Local runtime files
logs/
*.log
storage/*.db
storage/*.sqlite
instance/*.db
instance/*.sqlite
instance/*.sqlite3

# Never bake customer payment evidence or private storage into an image.
app/static/uploads/billing/
instance/private_uploads/
storage/private_uploads/

# Development-only material not required in the production image
tests/
tools/
DOCUMENTATION/
_legacy_unused/
*.bak
.tmp_*
