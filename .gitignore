# ============================================================
# Portfolio CMS — .gitignore
# ============================================================

# ── Secrets & environment ────────────────────────────────────
.env
.env.*
!.env.example
!.env.template
env.production.*
instance/
*.pem
*.key
*.p12
*.pfx
secrets/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib64/
.eggs/

# ── Virtual environments ─────────────────────────────────────
venv/
.venv/
env/
ENV/
.env/

# ── Type checking / linting caches ──────────────────────────
.mypy_cache/
.ruff_cache/
.pylint.d/
.pytype/

# ── Testing ──────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Uploads & media ──────────────────────────────────────────
app/static/uploads/
logs/
*.log

# ── Database (local dev only) ────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── IDE / OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Docker ───────────────────────────────────────────────────
.docker/

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
.cache/
