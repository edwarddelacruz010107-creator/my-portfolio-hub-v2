# .env.production — Portfolio CMS v5.0 Production Configuration
# 
# DEPLOYMENT INSTRUCTIONS:
# 1. Do NOT commit this file to version control
# 2. Set all variables in your Render dashboard (Settings → Environment)
# 3. Generate SECRET_KEY and FERNET_KEY with the commands shown below
# 4. Provision ONE PostgreSQL database for Option 1 deployment
#
# Generate SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Generate FERNET_KEY:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ─────────────────────────────────────────────────────────────────────────────
# FLASK CORE
# ─────────────────────────────────────────────────────────────────────────────

FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=change-me-generate-with-secrets-token-urlsafe

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY & ENCRYPTION
# ─────────────────────────────────────────────────────────────────────────────

# Fernet key for API key encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generate-with-cryptography-fernet

# TOTP Settings
TOTP_ISSUER=Portfolio CMS
TOTP_VALID_WINDOW=1
OTP_EXPIRATION_SECONDS=600
OTP_MAX_ATTEMPTS=5

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — OPTION 1 SINGLE-POSTGRES DEPLOYMENT
# ─────────────────────────────────────────────────────────────────────────────
#
# Recommended budget production setup for Render:
#   - Create ONE PostgreSQL database.
#   - Put its internal connection string in CORE_DATABASE_URL.
#   - Leave TENANT_DATABASE_URL blank to reuse the same physical database.
#
# The app still keeps the SQLAlchemy tenant bind, so you can later move tenant
# content to a separate database by filling TENANT_DATABASE_URL with a second
# Postgres URL.
#
# Format: postgresql://username:password@host:5432/database_name

CORE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/PORTFOLIO_DATABASE
TENANT_DATABASE_URL=



# ─────────────────────────────────────────────────────────────────────────────
# DOCKER / RENDER STARTUP CONTROLS
# ─────────────────────────────────────────────────────────────────────────────
# Set RUN_MIGRATIONS=true on Render Docker deployments so the container applies
# migrations before Gunicorn starts. Set CREATE_SUPERADMIN_ON_STARTUP=true only
# on first deploy, then switch it back to false after the account exists.

RUN_MIGRATIONS=true
USE_ORM_BOOTSTRAP_ON_STARTUP=true
ALLOW_CREATE_ALL_BOOTSTRAP_ON_MIGRATION_FAILURE=true
CREATE_SUPERADMIN_ON_STARTUP=false
AUTO_ENSURE_TENANT_SCHEMA=false

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL SERVICE — SUPERADMIN PROVIDER CHAIN
# ─────────────────────────────────────────────────────────────────────────────
#
# Signup OTP and password/security email use SuperAdmin → Email & Forms provider priority.
# Configure MailerSend, SMTP, and/or Resend in the SuperAdmin panel; env vars are fallback only.
#
# Setup:
#   1. Create account at https://mailersend.com
#   2. Generate API token in Dashboard → API Tokens
#   3. Verify a sending domain (e.g., noreply@yourdomain.com)
#   4. Set MAILERSEND_FROM_EMAIL to that verified address

MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=verified-sender@your-domain.example
MAILERSEND_FROM_NAME=MyPortfolioHub
SUPERADMIN_REPLY_TO_EMAIL=support@your-domain.example

# Deliverability DNS notes for your production sending domain:
# - Add SPF for the active sending provider from its dashboard.
# - Add DKIM records generated by MailerSend/Resend.
# - Add DMARC. Start with:
#   v=DMARC1; p=none; rua=mailto:postmaster@your-domain.example
# - After successful testing, consider:
#   v=DMARC1; p=quarantine; rua=mailto:postmaster@your-domain.example

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENT PROCESSING — PAYMONGO (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────
#
# Requires account at https://dashboard.paymongo.com
# Enable billing and payment processing for portfolio tenants.

PAYMONGO_ENABLED=false
PAYMONGO_PUBLIC_KEY=
PAYMONGO_SECRET_KEY=change-me-generate-with-secrets-token-urlsafe
PAYMONGO_WEBHOOK_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH (Sign-In — second login method for EXISTING tenant admins)
# ─────────────────────────────────────────────────────────────────────────────
#
# Requires an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
#   Application type: Web application
#   Authorized redirect URI: https://<your-domain>/auth/google/callback
#
# Feature is fully inert (button hidden, routes decline gracefully) unless
# BOTH values below are set. Leave both blank to keep Google Sign-In off.
# Does NOT create tenants or users — see app/auth/oauth.py.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# GITHUB OAUTH (Sign in + Create account)
# ─────────────────────────────────────────────────────────────────────────────
#
# Create a GitHub OAuth App at https://github.com/settings/developers
#   Homepage URL: https://<your-domain>
#   Authorization callback URL: https://<your-domain>/auth/github/callback
#
# Required scopes are requested by the app: read:user user:email.
# Leave both blank to keep GitHub auth disabled.

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# CACHING & RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
#
# Render auto-injects REDIS_URL when you provision a Redis service.
# No manual configuration needed if you're using Render's Redis.

REDIS_URL=

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for webhook redirects, payment callbacks, etc.
# Must be publicly accessible and match your Render domain.
APP_BASE_URL=https://your-production-domain.example

# Custom domains. Tenants should CNAME their hostname to CUSTOM_DOMAIN_CNAME_TARGET.
# Leave blank to use the APP_BASE_URL host as the default target.
CUSTOM_DOMAIN_CNAME_TARGET=your-production-domain.example
CUSTOM_DOMAIN_BLOCKED_HOSTS=your-production-domain.example
CUSTOM_DOMAIN_PUBLIC_SCHEME=https

# Billing grace period (days) — tenants can access features after expiration
BILLING_GRACE_PERIOD_DAYS=3

# Payment operation timeout (seconds)
PAYMENT_TIMEOUT_SECONDS=600

# ─────────────────────────────────────────────────────────────────────────────
# FILE STORAGE — SUPABASE (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────
#
# Enable Supabase for cloud storage of portfolio media.
# If disabled (default), files stored locally in /static/uploads
#
# Setup:
#   1. Create project at https://supabase.com
#   2. Create storage bucket named "portfolio-media"
#   3. Generate service key in Project Settings → API
#   4. Set USE_SUPABASE_STORAGE=true to enable

USE_SUPABASE_STORAGE=false
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=portfolio-media

# ─────────────────────────────────────────────────────────────────────────────
# MONITORING & ERROR TRACKING (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────

# Sentry for error tracking
# Get DSN from https://sentry.io/
SENTRY_DSN=

# BetterStack heartbeat for uptime monitoring
# Create endpoint at https://betterstack.com
BETTERSTACK_HEARTBEAT_URL=
HEARTBEAT_SECRET=

# Self-ping for health check (useful for monitoring)
SELF_PING_ENABLED=true
SELF_PING_INTERVAL=60
SELF_PING_BASE_URL=https://your-production-domain.example

# ─────────────────────────────────────────────────────────────────────────────
# CONTACT FORMS (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────
#
# Admin email for platform-level notifications
ADMIN_EMAIL=postmaster@your-domain.example

# ─────────────────────────────────────────────────────────────────────────────
# SUPERADMIN SETUP (FIRST LOGIN ONLY)
# ─────────────────────────────────────────────────────────────────────────────
#
# Only needed when first running `flask create-superadmin`
# Change password immediately after first login.
# NEVER commit a real password — this is for deployment setup only.

SUPERADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT CHECKLIST (Before enabling in Render)
# ─────────────────────────────────────────────────────────────────────────────
#
# ✓ FLASK_ENV=production
# ✓ SECRET_KEY generated and set
# ✓ FERNET_KEY generated and set
# ✓ CORE_DATABASE_URL configured with your single Render PostgreSQL URL
# ✓ TENANT_DATABASE_URL intentionally blank unless using a second database
 # ✓ Configure SuperAdmin → Email & Forms, or set env email provider fallback
# ✓ MAILERSEND_FROM_EMAIL verified in MailerSend
# ✓ PAYMONGO_* configured if billing enabled
# ✓ REDIS_URL configured (auto-injected by Render)
# ✓ APP_BASE_URL matches your Render domain
# ✓ Pre-deploy test: `flask db upgrade && flask ensure-tenant-schema && flask ensure-default-tenant`
# ✓ Health check: `/heartbeat` returns 200 OK
