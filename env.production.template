# .env.production — Portfolio CMS v5.0 Production Configuration
# 
# DEPLOYMENT INSTRUCTIONS:
# 1. Do NOT commit this file to version control
# 2. Set all variables in your Render dashboard (Settings → Environment)
# 3. Generate SECRET_KEY and FERNET_KEY with the commands shown below
# 4. Provision TWO PostgreSQL databases (core + tenant)
#
# Generate SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Generate FERNET_KEY:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ─────────────────────────────────────────────────────────────────────────────
# FLASK CORE
# ─────────────────────────────────────────────────────────────────────────────

FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=<REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))">

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY & ENCRYPTION
# ─────────────────────────────────────────────────────────────────────────────

# Fernet key for API key encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=<REQUIRED: Generate with Fernet.generate_key().decode()>

# TOTP Settings
TOTP_ISSUER=Portfolio CMS
TOTP_VALID_WINDOW=1
OTP_EXPIRATION_SECONDS=600
OTP_MAX_ATTEMPTS=5

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — DUAL-DATABASE ARCHITECTURE (v5.0)
# ─────────────────────────────────────────────────────────────────────────────
#
# CRITICAL: Portfolio CMS requires TWO separate PostgreSQL databases:
#   1. CORE_DATABASE_URL: Authentication, billing, tenants, platform config
#   2. TENANT_DATABASE_URL: Portfolio content, projects, forms, messages
#
# On Render, create two PostgreSQL services and copy their connection strings.
# Format: postgresql://username:password@host:5432/database_name

CORE_DATABASE_URL=<REQUIRED: PostgreSQL connection string for core database>
TENANT_DATABASE_URL=<REQUIRED: PostgreSQL connection string for tenant database>

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL SERVICE — MAILERSEND (v5.0, SOLE PROVIDER)
# ─────────────────────────────────────────────────────────────────────────────
#
# Flask-Mail and SMTP removed in v5.0.
# All transactional email routes through MailerSend API.
#
# Setup:
#   1. Create account at https://mailersend.com
#   2. Generate API token in Dashboard → API Tokens
#   3. Verify a sending domain (e.g., noreply@yourdomain.com)
#   4. Set MAILERSEND_FROM_EMAIL to that verified address

MAILERSEND_API_KEY=<REQUIRED: From app.mailersend.com → API Tokens>
MAILERSEND_FROM_EMAIL=<REQUIRED: Verified domain (e.g., noreply@yourdomain.com)>
MAILERSEND_FROM_NAME=Portfolio CMS

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENT PROCESSING — PAYMONGO (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────
#
# Requires account at https://dashboard.paymongo.com
# Enable billing and payment processing for portfolio tenants.

PAYMONGO_ENABLED=true
PAYMONGO_PUBLIC_KEY=<From PayMongo Dashboard → API Keys>
PAYMONGO_SECRET_KEY=<From PayMongo Dashboard → API Keys>
PAYMONGO_WEBHOOK_SECRET=<From PayMongo Dashboard → Webhooks>

# ─────────────────────────────────────────────────────────────────────────────
# CACHING & RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
#
# Render auto-injects REDIS_URL when you provision a Redis service.
# No manual configuration needed if you're using Render's Redis.

REDIS_URL=<AUTO: Render injects this. Leave empty if not using Redis.>

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for webhook redirects, payment callbacks, etc.
# Must be publicly accessible and match your Render domain
APP_BASE_URL=https://<your-app>.onrender.com

# Billing grace period (days) — tenants can access features after expiration
BILLING_GRACE_PERIOD_DAYS=3

# Payment operation timeout (seconds)
PAYMENT_TIMEOUT_SECONDS=600

# ─────────────────────────────────────────────────────────────────────────────
# FILE STORAGE — SUPABASE (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────
#
# Enable Supabase for cloud storage of portfolio media.
# If disabled (default), files stored locally in /static/uploads
#
# Setup:
#   1. Create project at https://supabase.com
#   2. Create storage bucket named "portfolio-media"
#   3. Generate service key in Project Settings → API
#   4. Set USE_SUPABASE_STORAGE=true to enable

USE_SUPABASE_STORAGE=false
SUPABASE_URL=<Optional: From Supabase Project Settings>
SUPABASE_SERVICE_KEY=<Optional: Service key from Supabase>
SUPABASE_BUCKET=portfolio-media

# ─────────────────────────────────────────────────────────────────────────────
# MONITORING & ERROR TRACKING (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────

# Sentry for error tracking
# Get DSN from https://sentry.io/
SENTRY_DSN=

# BetterStack heartbeat for uptime monitoring
# Create endpoint at https://betterstack.com
BETTERSTACK_HEARTBEAT_URL=
HEARTBEAT_SECRET=

# Self-ping for health check (useful for monitoring)
SELF_PING_ENABLED=true
SELF_PING_INTERVAL=60

# ─────────────────────────────────────────────────────────────────────────────
# CONTACT FORMS (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────
#
# Admin email for platform-level notifications
ADMIN_EMAIL=<Your admin email address>

# ─────────────────────────────────────────────────────────────────────────────
# SUPERADMIN SETUP (FIRST LOGIN ONLY)
# ─────────────────────────────────────────────────────────────────────────────
#
# Only needed when first running `flask create-superadmin`
# Change password immediately after first login.
# NEVER commit a real password — this is for deployment setup only.

SUPERADMIN_PASSWORD=<Change immediately after first login>

# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT CHECKLIST (Before enabling in Render)
# ─────────────────────────────────────────────────────────────────────────────
#
# ✓ FLASK_ENV=production
# ✓ SECRET_KEY generated and set
# ✓ FERNET_KEY generated and set
# ✓ CORE_DATABASE_URL configured (PostgreSQL #1)
# ✓ TENANT_DATABASE_URL configured (PostgreSQL #2)
# ✓ MAILERSEND_API_KEY set (transactional email required)
# ✓ MAILERSEND_FROM_EMAIL verified in MailerSend
# ✓ PAYMONGO_* configured if billing enabled
# ✓ REDIS_URL configured (auto-injected by Render)
# ✓ APP_BASE_URL matches your Render domain
# ✓ Pre-deploy test: `flask db upgrade && flask ensure-default-tenant`
# ✓ Health check: `/heartbeat` returns 200 OK
