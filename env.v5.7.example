# ─────────────────────────────────────────────────────────────────────────────
# Portfolio CMS v5.7 — Email Delivery Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── SMTP (superadmin: SOLE provider | admin/tenant: FALLBACK provider) ──────
SMTP_ENABLED=true                      # admin/tenant fallback tier gate.
                                        # NOTE: smtp_service.py (superadmin) does
                                        # NOT read this flag — it is unconditional
                                        # for the superadmin path by design.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587                          # 587 = STARTTLS (recommended) | 465 = implicit TLS
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password       # store as a secret, never commit
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Portfolio CMS

# ── MailerSend (admin/tenant: PRIMARY provider) ──────────────────────────────
# Can also be set via Superadmin → Email Settings (DB, Fernet-encrypted) —
# DB value takes priority over these env vars when present.
MAILERSEND_API_KEY=your-shared-mailersend-key
ADMIN_MAILERSEND_API_KEY=              # optional — falls back to MAILERSEND_API_KEY
SUPERADMIN_MAILERSEND_API_KEY=         # unused as of v5.7 (superadmin = SMTP only);
                                        # retained for schema/back-compat only

# ── Web3Forms (UNRELATED to password reset — tenant contact-form feature only) ──
# Do NOT remove. Used as the GLOBAL DEFAULT key for tenants whose own
# TenantCommunicationSettings.web3forms_key is unset (per-tenant contact
# forms in app/services/forms.py). Has zero involvement in OTP/password
# reset as of v5.7.
WEB3FORMS_ACCESS_KEY=your-key-from-web3forms.com

# ── Removed in v5.7 (superadmin OTP no longer uses Web3Forms) ───────────────
# OWNER_EMAIL was only consumed by app/services/web3forms_service.py for
# superadmin OTP delivery. That module is retired. Safe to delete this var.
# OWNER_EMAIL=
