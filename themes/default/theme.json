{
  "id": "default",
  "name": "Default Clean",
  "version": "1.0.0",
  "description": "A clean, minimal portfolio theme with light and dark mode support. Professional and accessible, works for all industries.",
  "author": "Portfolio CMS",
  "premium": false,
  "preview_image": "/static/themes/default/preview.svg",
  "supports_dark_mode": true,
  "supports_light_mode": true,
  "supports_animation": true,
  "supports_custom_colors": true,
  "supports_blog": true,
  "supports_testimonials": true,
  "supports_services": true,
  "supports_projects": true,
  "supports_skills": true,
  "supports_contact_form": true,
  "compatibility_version": "6.3",
  "tags": ["minimal", "clean", "professional", "light", "dark"],
  "color_scheme": {
    "primary": "#3b82f6",
    "secondary": "#8b5cf6",
    "accent": "#10b981",
    "background": "#ffffff",
    "text": "#1f2937"
  }
}
